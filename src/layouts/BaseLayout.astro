---
import type { Locale } from '../i18n/index';
import { t, getLocalizedPath, getAlternateLocale } from '../i18n/index';
import '../styles/global.css';

interface Props {
  title?: string;
  locale: Locale;
  currentPath?: string;
}

const { title, locale, currentPath = '' } = Astro.props;
const i18n = t(locale);
const altLocale = getAlternateLocale(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Collegiate Shag Workshops in Salzburg — Swing Dance Classes" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title ? `${title} | Shagadeus` : 'Shagadeus — Collegiate Shag in Salzburg'}</title>
  </head>
  <body class="min-h-screen bg-bg text-text flex flex-col font-sans" style="visibility:hidden">
    <!-- Auth gate spinner (removed after auth check) -->
    <div id="auth-gate" style="position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:#FFF8F0;z-index:9999;visibility:visible">
      <div style="width:2rem;height:2rem;border:4px solid rgba(0,0,0,0.1);border-top-color:#1a2744;border-radius:50%;animation:spin .8s linear infinite"></div>
      <style>@keyframes spin{to{transform:rotate(360deg)}}</style>
    </div>
    <!-- Header -->
    <header class="sticky top-0 z-50 backdrop-blur-md bg-bg/70 border-b border-primary/5">
      <nav class="max-w-6xl mx-auto px-5 sm:px-6 py-3.5 flex items-center justify-between gap-4">
        <a href={`${base}/${locale}/`} class="group flex items-center gap-3 hover:opacity-95 transition-opacity">
          <span class="relative">
            <span class="absolute inset-0 rounded-xl bg-gradient-to-br from-coral/30 to-accent/30 blur-md opacity-0 group-hover:opacity-100 transition-opacity"></span>
            <img src={`${base}/shagadeus_logo.png`} alt="Shagadeus" class="relative h-10 w-auto rounded-xl shadow-soft" />
          </span>
          <span class="font-display text-xl font-bold text-primary hidden sm:inline tracking-tight">Shagadeus</span>
        </a>

        <div class="flex items-center gap-1 sm:gap-2">
          <a href={`${base}/${locale}/`} class="hidden sm:inline-block px-3 py-2 text-sm font-medium text-text/80 hover:text-primary rounded-full transition-colors">
            {i18n.nav.home}
          </a>
          <a href={`${base}/${locale}/about/`} class="hidden sm:inline-block px-3 py-2 text-sm font-medium text-text/80 hover:text-primary rounded-full transition-colors">
            {i18n.nav.about}
          </a>
          <a
            href={`${base}/${locale}/workshops/`}
            class="ml-1 inline-flex items-center gap-1.5 bg-gradient-to-br from-coral to-coral-dark hover:from-coral-dark hover:to-coral text-white font-semibold px-4 sm:px-5 py-2 rounded-full text-sm shadow-[0_6px_18px_-6px_rgba(231,111,81,0.6)] transition-all hover:-translate-y-0.5"
          >
            {i18n.home.hero_cta}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a
            href={`${base}/${altLocale}${currentPath}`}
            class="ml-1 inline-flex items-center justify-center min-w-[2.25rem] h-9 border border-primary/15 hover:border-primary/30 text-primary/80 hover:text-primary rounded-full px-2 text-[11px] font-bold tracking-wider transition-colors"
          >
            {i18n.nav.language}
          </a>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative mt-24 bg-gradient-to-br from-primary via-primary to-ink text-white/80 overflow-hidden">
      <!-- decorative blobs -->
      <div class="blob bg-coral/30 w-72 h-72 -top-20 -left-10"></div>
      <div class="blob bg-teal/25 w-80 h-80 -bottom-32 right-0"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-14 pb-10">
        <div class="grid gap-10 sm:grid-cols-3 mb-10">
          <div class="sm:col-span-1">
            <div class="flex items-center gap-3 mb-4">
              <img src={`${base}/shagadeus_logo.png`} alt="Shagadeus" class="h-10 w-auto rounded-lg" />
              <span class="font-display text-xl font-bold text-white tracking-tight">Shagadeus</span>
            </div>
            <p class="text-sm text-white/55 leading-relaxed max-w-xs">
              {locale === 'de' ? 'Collegiate Shag Workshops & Tanzkurse in Salzburg.' : 'Collegiate Shag workshops & dance classes in Salzburg.'}
            </p>
          </div>

          <div>
            <p class="eyebrow text-accent/90 mb-3">{locale === 'de' ? 'Navigation' : 'Navigation'}</p>
            <ul class="space-y-2 text-sm">
              <li><a href={`${base}/${locale}/`} class="text-white/70 hover:text-white transition-colors">{i18n.nav.home}</a></li>
              <li><a href={`${base}/${locale}/about/`} class="text-white/70 hover:text-white transition-colors">{i18n.nav.about}</a></li>
              <li><a href={`${base}/${locale}/workshops/`} class="text-white/70 hover:text-white transition-colors">{i18n.home.hero_cta}</a></li>
            </ul>
          </div>

          <div>
            <p class="eyebrow text-accent/90 mb-3">{locale === 'de' ? 'Rechtliches' : 'Legal'}</p>
            <ul class="space-y-2 text-sm">
              <li><a href={`${base}/${locale}/impressum/`} class="text-white/70 hover:text-white transition-colors">{i18n.footer.imprint}</a></li>
            </ul>
          </div>
        </div>

        <div class="pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/50">
          <span>Salzburg, Österreich · Collegiate Shag</span>
          <span class="font-display italic text-accent/80">— let's swing —</span>
        </div>
      </div>
    </footer>

    <!-- AUTH GATE: Remove this script block when the site goes public -->
    <script>
      import { supabase } from '../lib/supabase';
      const base = import.meta.env.BASE_URL?.replace(/\/$/, '') ?? '';
      supabase.auth.getUser().then(({ data: { user } }) => {
        if (!user) {
           window.location.href = `${base}/admin/login/?returnTo=${encodeURIComponent(window.location.pathname + window.location.search)}`;
        } else {
          document.body.style.visibility = 'visible';
          document.getElementById('auth-gate')?.remove();
        }
      });
    </script>
  </body>
</html>
