---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/index';
import ClassList from '../../components/ClassList';

const locale = 'en';
const i18n = t(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={i18n.nav.home} locale={locale}>
  <!-- Hero Section — compact split layout -->
  <section class="bg-bg border-b border-bg-warm">
    <div class="max-w-5xl mx-auto px-6 py-8 sm:py-10">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-10">

        <!-- Logo -->
        <div class="shrink-0">
          <img
            src={`${base}/shagadeus_logo.png`}
            alt="Shagadeus"
            class="w-44 sm:w-52 h-auto rounded-2xl drop-shadow-md"
          />
        </div>

        <!-- Text & CTA -->
        <div class="text-center sm:text-left">
          <h1 class="font-display text-4xl sm:text-5xl font-black text-primary leading-tight mb-2">
            {i18n.home.hero_title}
          </h1>
          <p class="text-teal font-semibold text-base mb-1">Salzburg, Austria</p>
          <p class="text-coral font-display italic text-lg mb-5">{i18n.home.hero_subtitle}</p>
          <div class="flex flex-wrap gap-3 justify-center sm:justify-start">
            <a
              href={`${base}/en/workshops/`}
              class="inline-block bg-coral hover:bg-coral-dark text-white font-bold px-6 py-2.5 rounded-full transition-colors text-sm shadow-sm"
            >
              {i18n.home.hero_cta}
            </a>
            <a
              href={`${base}/en/about/`}
              class="inline-block bg-teal hover:bg-teal-dark text-white font-bold px-6 py-2.5 rounded-full transition-colors text-sm shadow-sm"
            >
              {i18n.home.hero_about}
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Current Workshops -->
  <section id="workshops" class="max-w-5xl mx-auto px-6 py-8 sm:py-10">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-primary shrink-0">
        {i18n.home.current_workshops}
      </h2>
      <span class="h-px flex-1 bg-teal/20"></span>
      <span class="text-teal text-sm opacity-60">✦</span>
    </div>
    <ClassList client:load locale={locale} />
  </section>
</BaseLayout>
