---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/index';
import ClassList from '../../components/ClassList';

const locale = 'en';
const i18n = t(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={i18n.nav.home} locale={locale}>
  <!-- Hero Section — modern with gradient blobs -->
  <section class="relative overflow-hidden">
    <div class="blob bg-coral/35 w-[28rem] h-[28rem] -top-32 -left-32 animate-float-slow"></div>
    <div class="blob bg-teal/30 w-[26rem] h-[26rem] -top-20 right-[-6rem] animate-float-slow" style="animation-delay: -4s"></div>
    <div class="blob bg-accent/25 w-72 h-72 bottom-[-4rem] left-1/3"></div>

    <div class="relative max-w-6xl mx-auto px-6 pt-16 pb-20 sm:pt-24 sm:pb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <div class="lg:col-span-7 text-center lg:text-left animate-fade-up">
          <span class="inline-flex items-center gap-2 eyebrow text-teal-dark bg-white/60 backdrop-blur-sm border border-teal/20 rounded-full px-3.5 py-1.5 mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></span>
            Salzburg · Austria
          </span>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-black text-primary leading-[1.02] mb-5">
            <span class="block">Collegiate</span>
            <span class="block italic font-normal text-gradient-warm">Shag</span>
            <span class="block">Salzburg</span>
          </h1>
          <p class="text-text-muted text-lg sm:text-xl max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
            {i18n.home.hero_subtitle} — Energetic swing dance classes for all levels.
          </p>
          <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
            <a href={`${base}/en/workshops/`} class="btn-primary">
              {i18n.home.hero_cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <a href={`${base}/en/about/`} class="btn-ghost">
              {i18n.home.hero_about}
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 flex justify-center lg:justify-end animate-fade-up" style="animation-delay: 0.15s">
          <div class="relative">
            <div class="absolute inset-0 -m-6 bg-gradient-to-br from-coral/30 via-accent/25 to-teal/30 blur-2xl rounded-[2.5rem]"></div>
            <div class="relative bg-white/70 backdrop-blur-sm border border-white/80 rounded-[2rem] p-6 shadow-lift rotate-[-3deg] hover:rotate-0 transition-transform duration-500">
              <img
                src={`${base}/shagadeus_logo.png`}
                alt="Shagadeus"
                class="w-56 sm:w-64 h-auto rounded-2xl drop-shadow-md"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Workshops -->
  <section id="workshops" class="relative max-w-6xl mx-auto px-6 py-12 sm:py-16">
    <div class="flex items-end justify-between gap-4 mb-10">
      <div>
        <p class="eyebrow text-coral mb-2">Program</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-primary tracking-tight">
          {i18n.home.current_workshops}
        </h2>
      </div>
      <span class="hidden sm:block h-px flex-1 bg-gradient-to-r from-transparent via-primary/15 to-transparent mb-3"></span>
      <span class="text-accent text-2xl mb-1">✦</span>
    </div>
    <ClassList client:load locale={locale} />
  </section>
</BaseLayout>
